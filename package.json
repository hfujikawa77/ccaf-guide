{
  "name": "ccaf-guide",
  "version": "0.1.0",
  "private": true,
  "description": "Unofficial CCA-F (Claude Certified Architect - Foundations) study guide",
  "scripts": {
    "dev": "node scripts/generate-seo.mjs && next dev",
    "build": "next build",
    "prebuild": "node scripts/generate-seo.mjs",
    "postbuild": "pagefind --site out --output-subdir _pagefind",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "preview": "npx serve out",
    "preview:cf": "wrangler dev",
    "deploy": "wrangler deploy",
    "changelog": "git-cliff --include-path 'content/**' -o CHANGELOG.md"
  },
  "dependencies": {
    "next": "15.5.15",
    "nextra": "4.6.1",
    "nextra-theme-docs": "4.6.1",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "git-cliff": "2.13.1",
    "pagefind": "1.5.2",
    "typescript": "5.7.3",
    "wrangler": "4.85.0"
  }
}
